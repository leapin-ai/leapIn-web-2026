---
import { pxToRem } from '../../utils';
import bgBottom1 from '../../assets/index/bg_linear_1.png';
import logo1 from '../../assets/index/partner/logo1.png';
import logo2 from '../../assets/index/partner/logo2.png';
import logo3 from '../../assets/index/partner/logo3.png';
import logo4 from '../../assets/index/partner/logo4.png';
import logo5 from '../../assets/index/partner/logo5.png';
import logo6 from '../../assets/index/partner/logo6.png';
import logo7 from '../../assets/index/partner/logo7.png';
import logo8 from '../../assets/index/partner/logo8.png';
import logo9 from '../../assets/index/partner/logo9.png';
import avatar1 from '../../assets/index/partner/user/1.png';
import avatar2 from '../../assets/index/partner/user/2.png';
import avatar3 from '../../assets/index/partner/user/3.png';

const logos = [
  { src: logo1, width: 103, mobileWidth: 40 },
  { src: logo2, width: 85, mobileWidth: 33 },
  { src: logo3, width: 143, mobileWidth: 56 },
  { src: logo4, width: 137, mobileWidth: 54 },
  { src: logo5, width: 84, mobileWidth: 33 },
  { src: logo6, width: 180, mobileWidth: 70 },
  { src: logo7, width: 78, mobileWidth: 30 },
  { src: logo8, width: 93, mobileWidth: 36 },
  { src: logo9, width: 204, mobileWidth: 80 },
];

const avatars = [avatar1, avatar2, avatar3];
---
<section class="partners">
  <div class="container">
    <h2 class="partners-title" data-i18n="homepage.partners.title">深受全球企业信赖</h2>
    <p class="partners-description" data-i18n="homepage.partners.description">服务于全球 8 大主要行业的领先组织</p>
    <div class="partners-scroll">
      <div class="partners-track">
        {logos.map(({ src, width, mobileWidth }, index) => (
          <div class="partner-item">
            <img 
              src={src.src} 
              alt={`Partner ${index + 1}`}
              style={`width: ${pxToRem(width)};`}
              data-mobile-width={pxToRem(mobileWidth)}
            />
          </div>
        ))}
        {logos.map(({ src, width, mobileWidth }, index) => (
          <div class="partner-item">
            <img 
              src={src.src} 
              alt={`Partner ${index + 1}`}
              style={`width: ${pxToRem(width)};`}
              data-mobile-width={pxToRem(mobileWidth)}
            />
          </div>
        ))}
        {logos.map(({ src, width, mobileWidth }, index) => (
          <div class="partner-item">
            <img 
              src={src.src} 
              alt={`Partner ${index + 1}`}
              style={`width: ${pxToRem(width)};`}
              data-mobile-width={pxToRem(mobileWidth)}
            />
          </div>
        ))}
      </div>
    </div>

    <div class="partners-reviews">
      <button class="review-nav review-nav-prev" id="review-prev" aria-label="Previous review">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="partners-reviews-container">
        <div class="partners-reviews-track" id="reviews-track">
          {[0, 1, 2].map((index) => (
            <div class="partners-reviews-slide" data-index={index}>
              <div class="partners-reviews-left">
                <div class="reviews-left-quote" data-i18n="homepage.partners.quote">"</div>
                <div class="reviews-left-description" data-i18n={`homepage.partners.reviews.${index}.quote`}></div>
                <div class="reviews-left-user-wrap">
                  <img class="reviews-left-user-avatar" src={avatars[index].src} alt="User avatar" />
                  <div class="reviews-left-user-info">
                    <div class="reviews-left-user-name" data-i18n={`homepage.partners.reviews.${index}.name`}></div>
                    <div class="reviews-left-user-position" data-i18n={`homepage.partners.reviews.${index}.position`}></div>
                  </div>
                </div>
              </div>
              <div class="partners-reviews-right">
                <div class="reviews-data" data-i18n={`homepage.partners.reviews.${index}.stat`}></div>
                <div class="reviews-data-info" data-i18n={`homepage.partners.reviews.${index}.statLabel`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <button class="review-nav review-nav-next" id="review-next" aria-label="Next review">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style define:vars={{ 
  bgBottom1: `url(${bgBottom1.src})`,
}}>
  .partners {
    padding-top: 4.75rem;
    /* padding: 4rem 0; */
    position: relative;
    overflow: hidden;
  }

  .partners::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    top: 0;
		background-image: var(--bgBottom1);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    transform: scaleY(-1);
    z-index: -1;
  }

  .container {
    max-width: 100%;
    padding: 0;
    overflow: hidden;
  }

  .partners-title {
    text-align: center;
    font-size: 2.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 4rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .partners-description {
    text-align: center;
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--grey-gray-60-base, #111827);
    margin-bottom: 5.625rem;
  }

  .partners-scroll {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .partners-track {
    display: flex;
    animation: scroll 8s linear infinite;
    width: max-content;
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }

  .partner-item {
    flex-shrink: 0;
    margin-right: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .partner-item img {
    object-fit: contain;
    backface-visibility: hidden;
    -webkit-font-smoothing: antialiased;
    transform: translateZ(0);
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
  }

  @keyframes scroll {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(calc(-100% / 3), 0, 0);
    }
  }

  /* Reviews Section */
  .partners-reviews {
    position: relative;
    margin: 5rem auto 0;
    max-width: var(--max-width);
    padding: 0 4rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .review-nav {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: 2px solid #E5E7EB;
    background: white;
    color: #111827;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s;
    z-index: 2;
  }

  .review-nav:hover {
    border-color: #8B5CF6;
    color: #8B5CF6;
    transform: scale(1.1);
  }

  .review-nav:active {
    transform: scale(0.95);
  }

  .partners-reviews-container {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .partners-reviews-track {
    display: flex;
    transition: transform 0.6s ease-out;
    will-change: transform;
  }

  .partners-reviews-slide {
    min-width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
  }

  .partners-reviews-left {
    flex: 1;
  }

  .reviews-left-quote {
    font-size: 3.75rem;
    line-height: 1;
    background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .reviews-left-description {
    font-size: 1.25rem;
    line-height: 1.3;
    margin-bottom: 2rem;
    font-style: italic;
    color: var(--grey-gray-60-base, #111827);
  }

  .reviews-left-user-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .reviews-left-user-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    object-fit: cover;
  }

  .reviews-left-user-info {
    display: flex;
    flex-direction: column;
  }

  .reviews-left-user-name {
    font-size: 1.25rem;
    font-weight: 600;
    background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .reviews-left-user-position {
    font-size: 0.875rem;
    color: var(--Grey-Gray-40, rgba(17, 24, 39, 0.60));
    font-feature-settings: 'liga' off, 'clig' off;
    line-height: 128.571%;
  }

  .partners-reviews-right {
    display: flex;
    flex-direction: column;
    padding-left: 4rem;
    border-left: 1px solid #E5E7EB;
    width: 21.625rem;
    height: 11.5rem;
    justify-content: center;
    gap: 0.5rem;
  }

  .reviews-data {
    font-size: 6rem;
    font-weight: 700;
    background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .reviews-data-info {
    font-size: 1.25rem;
    color: #6B7280;
    color: var(--Grey-Gray-40, rgba(17, 24, 39, 0.60));
    font-weight: 600;
    line-height: 120%; /* 24px */
    text-transform: capitalize;
  }

  @media (max-width: 768px) {
    .partners {
      padding: 2rem 0;
    }

    .partners-track {
      animation-duration: 10s;
    }

    .partner-item {
      flex-shrink: 0;
      margin-right: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .partners-title {
      font-size: 1.5rem;
      margin-top: 0;
      text-align: left;
      padding: 0 1rem;
    }

    .partners-description {
      font-size: 0.875rem;
      margin-bottom: 4rem;
      padding: 0 1rem;
      text-align: left;
    }

    .partners-reviews {
      padding: 0 1rem;
      margin: 3rem auto 0;
      gap: 1rem;
    }

    .review-nav {
      width: 2.5rem;
      height: 2.5rem;
    }

    .review-nav svg {
      width: 20px;
      height: 20px;
    }

    .partners-reviews-slide {
      flex-direction: column;
      gap: 2rem;
    }

    .partners-reviews-left {
      max-width: 100%;
    }

    .reviews-left-quote {
      font-size: 3rem;
    }

    .reviews-left-description {
      font-size: 1rem;
    }

    .partners-reviews-right {
      border-left: none;
      border-top: 1px solid var(--grey-gray-60-base, #111827);
      width: 100%;
      padding: 1.5rem 0 0;
      align-items: flex-start;
      height: fit-content;
    }

    .reviews-data {
      font-size: 3rem;
    }

    .reviews-data-info {
      font-size: 0.875rem;
      max-width: auto;
    }
  }
</style>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  
  loadTranslations();

  // 应用移动端宽度
  function applyMobileWidths() {
    const isMobile = window.innerWidth <= 768;
    const images = document.querySelectorAll('.partner-item img');
    
    images.forEach((img) => {
      const mobileWidth = img.getAttribute('data-mobile-width');
      if (isMobile && mobileWidth) {
        (img as HTMLElement).style.width = mobileWidth;
      }
    });
  }

  applyMobileWidths();
  window.addEventListener('resize', applyMobileWidths);

  // 客户评价轮播
  let currentReviewIndex = 0;
  const totalReviews = 3;
  let reviewInterval: number;

  const track = document.getElementById('reviews-track');
  const prevBtn = document.getElementById('review-prev');
  const nextBtn = document.getElementById('review-next');

  function updateReviewPosition() {
    if (track) {
      track.style.transform = `translateX(-${currentReviewIndex * 100}%)`;
    }
  }

  function goToReview(index: number) {
    currentReviewIndex = (index + totalReviews) % totalReviews;
    updateReviewPosition();
  }

  function nextReview() {
    goToReview(currentReviewIndex + 1);
  }

  function prevReview() {
    goToReview(currentReviewIndex - 1);
  }

  function startReviewCarousel() {
    reviewInterval = window.setInterval(() => {
      nextReview();
    }, 2000); // 每2秒切换一次
  }

  function stopReviewCarousel() {
    if (reviewInterval) {
      clearInterval(reviewInterval);
    }
  }

  // 按钮事件
  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      prevReview();
      stopReviewCarousel();
      startReviewCarousel();
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      nextReview();
      stopReviewCarousel();
      startReviewCarousel();
    });
  }

  // 启动轮播
  startReviewCarousel();

  // 鼠标悬停时暂停轮播
  const reviewsSection = document.querySelector('.partners-reviews');
  if (reviewsSection) {
    reviewsSection.addEventListener('mouseenter', stopReviewCarousel);
    reviewsSection.addEventListener('mouseleave', startReviewCarousel);
  }

  // 页面卸载时清理
  window.addEventListener('beforeunload', stopReviewCarousel);
</script>
