---
import PlatformFeatureCard from './PlatformFeatureCard.astro';
---

<div class="platform-feature-container" id="platform-feature-container">
    <div class="feature-card-wrapper" data-index="0" data-active="false">
        <PlatformFeatureCard type='Acquisition' />
    </div>
    <div class="feature-card-wrapper" data-index="1" data-active="false">
        <PlatformFeatureCard type='Marketplace' />
    </div>
    <div class="feature-card-wrapper" data-index="2" data-active="false">
        <PlatformFeatureCard type='Development' />
    </div>
</div>

<style>
  .platform-feature-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feature-card-wrapper {
    position: absolute;
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    pointer-events: none;
  }

  /* Initial state - Card 0 (Acquisition) */
  .feature-card-wrapper[data-index="0"] {
    top: -20vh;
    transform: rotate(-45deg);
    opacity: 1;
  }

  /* Initial state - Card 1 (Marketplace) */
  .feature-card-wrapper[data-index="1"] {
    transform: rotate(45deg);
    opacity: 0;
  }

  /* Initial state - Card 2 (Development) */
  .feature-card-wrapper[data-index="2"] {
    transform: rotate(-45deg);
    opacity: 0;
  }

  /* Active state - all cards centered and straight */
  .feature-card-wrapper[data-active="true"] {
    top: 30vh !important;
    transform: rotate(0deg) !important;
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  /* Hidden state - cards that are not current */
  .feature-card-wrapper[data-active="false"]:not([data-index="0"]) {
    opacity: 0 !important;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .platform-feature-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: static;
      height: auto;
    }

    .feature-card-wrapper {
      position: static;
      transform: none !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      top: 0 !important;
    }
  }
</style>

<script>
  import { loadTranslations } from '../scripts/i18n-loader';
  loadTranslations();

  const container = document.getElementById('platform-feature-container');
  const scrollSection = document.querySelector('.scroll-section.features-dark');
  
  if (container && scrollSection) {
    let currentIndex = 0;
    const cards = container.querySelectorAll('.feature-card-wrapper');
    const totalCards = cards.length;
    let isScrolling = false;
    let isInViewport = false;

    // Update card visibility and animations
    const updateCards = (index: number) => {
      currentIndex = index;
      
      cards.forEach((card, i) => {
        if (i === index) {
          card.setAttribute('data-active', 'true');
        } else {
          card.setAttribute('data-active', 'false');
        }
      });
    };

    // Check if section is in viewport
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.3
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        isInViewport = entry.isIntersecting;
        
        if (isInViewport && currentIndex === 0) {
          // Activate first card when entering viewport
          updateCards(0);
        } else if (!isInViewport) {
          // Reset to initial state when leaving viewport
          currentIndex = 0;
          cards.forEach((card, i) => {
            card.setAttribute('data-active', 'false');
          });
        }
      });
    }, observerOptions);

    observer.observe(scrollSection);

    // Handle wheel scroll within the section
    const handleWheel = (e: WheelEvent) => {
      // Only handle scroll when in viewport and not currently scrolling
      if (!isInViewport || isScrolling) return;

      const scrollingDown = e.deltaY > 0;
      const scrollingUp = e.deltaY < 0;

      // Check if we should handle this scroll
      const shouldHandleDown = scrollingDown && currentIndex < totalCards - 1;
      const shouldHandleUp = scrollingUp && currentIndex > 0;

      if (shouldHandleDown || shouldHandleUp) {
        // Prevent default scroll behavior
        e.preventDefault();
        e.stopPropagation();
        
        isScrolling = true;

        if (shouldHandleDown) {
          updateCards(currentIndex + 1);
        } else if (shouldHandleUp) {
          updateCards(currentIndex - 1);
        }

        // Reset scrolling flag after animation
        setTimeout(() => {
          isScrolling = false;
        }, 800);
      }
      // If at boundaries, allow normal scroll to continue
    };

    // Listen to wheel events on the scroll section
    scrollSection.addEventListener('wheel', handleWheel, { passive: false });

    // Handle scroll position to determine card index
    let ticking = false;
    const handleScroll = () => {
      if (!ticking && isInViewport) {
        window.requestAnimationFrame(() => {
          const rect = scrollSection.getBoundingClientRect();
          const sectionHeight = scrollSection.offsetHeight;
          const viewportHeight = window.innerHeight;
          
          // Calculate scroll progress through the section
          const scrollProgress = Math.abs(rect.top) / (sectionHeight - viewportHeight);
          
          // Determine which card should be active based on scroll progress
          const newIndex = Math.min(
            Math.floor(scrollProgress * totalCards),
            totalCards - 1
          );
          
          if (newIndex !== currentIndex && !isScrolling) {
            updateCards(Math.max(0, newIndex));
          }
          
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
  }
</script>
