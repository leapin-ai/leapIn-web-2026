---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	pageName: string;
}

const { pageName } = Astro.props;
---

<Layout>
	<Header />
    <main>
        <section class="legal-hero">
            
        </section>
        <section class="legal-page">
            <div class="container">
                <h2 class="title" data-i18n={`legal.${pageName}.title`}></h2>
                <div class="content" data-i18n={`legal.${pageName}.content`}></div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();
</script>

<style>
    .legal-hero {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 22rem;
        background: linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%);
        filter: blur(50px);
        z-index: 0;
    }
	.legal-page {
        z-index: 1;
        position: relative;
		padding-top: 80px;
		min-height: 100vh;
	}
    .container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 3.125rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .title {
        text-align: center;
        color: var(--grey-gray-60-base, #111827);

        /* title */
        font-size: 2.5rem;
        line-height: 124%;
        letter-spacing: -0.44px;
    }

    .content {
        white-space: pre-wrap;
        color: var(--grey-gray-60-base, #111827);
        font-feature-settings: 'liga' off, 'clig' off;

        /* Body Text/01 Regular */
        font-family: Inter;
        font-size: 1rem;
        font-weight: 400;
        line-height: 137.5%;
    }

	@media (max-width: 768px) {
		.title {
			font-size: 1.5rem;
		}

        .container {
            gap: 1rem;
        }
	}
</style>