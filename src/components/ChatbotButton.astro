---
// Chatbot 悬浮按钮和弹窗组件 - 集成 Leapin AI Agent SDK
import AIIcon1 from '../assets/AIIcons.svg';
import AIIcon2 from '../assets/AIIcons2.svg';
import AIAvatar from '../assets/chatbot/AIAvatar.png';
import UserAvatar from '../assets/chatbot/UserAvatar.png';
import FullScreenIcon from '../assets/chatbot/fullScreen.svg';
import ShrinkScreenIcon from '../assets/chatbot/shirnkScreen.svg';
import SendIcon from '../assets/chatbot/send.svg';
import SoundIcon from '../assets/chatbot/sound.svg';
---

<div class="chatbot-container">
  <!-- 遮罩层 -->
  <div class="chatbot-overlay" id="chatbot-overlay"></div>
  
  <!-- 悬浮按钮 -->
  <button class="chatbot-button" id="chatbot-toggle" aria-label="Open AI Assistant">
    <img class="chatbot-icon" src={AIIcon1.src} alt="AI Icon" id="chatbot-icon" />
  </button>

  <!-- Chatbot 弹窗 -->
  <div class="chatbot-popup" id="chatbot-popup">
    <div class="chatbot-header">
      <div class="chatbot-header-content">
        <img class="chatbot-avatar" src={AIAvatar.src} alt="AI Avatar" />
        <div class="chatbot-info">
          <h3>AI Job Assistant</h3>
        </div>
      </div>
      <div class="chatbot-header-actions">
        <button class="icon-button" id="fullscreen-toggle" aria-label="Toggle fullscreen">
          <img src={FullScreenIcon.src} alt="Fullscreen" id="fullscreen-icon" />
        </button>
        <button class="icon-button" id="chatbot-close" aria-label="Close chat">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <div class="chatbot-messages" id="chatbot-messages">
      <div class="message bot-message">
        <img class="message-avatar" src={AIAvatar.src} alt="AI" />
        <div class="message-content">
          <p>Hi I'm Elsa, how can i help you today? You can ask me anything about our business, culture, team, and more. Or you can start with a quick action below.</p>
        </div>
      </div>
      <div class="quick-actions">
        <button class="quick-action-btn">LeapIn Introduction</button>
        <button class="quick-action-btn">Product & Solution</button>
      </div>
    </div>

    <div class="chatbot-footer">
      <div class="chatbot-input-container">
        <input 
          type="text" 
          class="chatbot-input" 
          id="chatbot-input"
          placeholder="Ask Elsa..."
          aria-label="Chat input"
        />
        <button class="icon-button" id="sound-button" aria-label="Voice input">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <mask id="mask0_1377_24474" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
              <rect width="24" height="24" fill="#D9D9D9"/>
            </mask>
            <g mask="url(#mask0_1377_24474)">
              <path d="M12 14C11.1667 14 10.4583 13.7083 9.875 13.125C9.29167 12.5417 9 11.8333 9 11V5C9 4.16667 9.29167 3.45833 9.875 2.875C10.4583 2.29167 11.1667 2 12 2C12.8333 2 13.5417 2.29167 14.125 2.875C14.7083 3.45833 15 4.16667 15 5V11C15 11.8333 14.7083 12.5417 14.125 13.125C13.5417 13.7083 12.8333 14 12 14ZM11 21V17.925C9.26667 17.6917 7.83333 16.9167 6.7 15.6C5.56667 14.2833 5 12.75 5 11H7C7 12.3833 7.4875 13.5625 8.4625 14.5375C9.4375 15.5125 10.6167 16 12 16C13.3833 16 14.5625 15.5125 15.5375 14.5375C16.5125 13.5625 17 12.3833 17 11H19C19 12.75 18.4333 14.2833 17.3 15.6C16.1667 16.9167 14.7333 17.6917 13 17.925V21H11ZM12 12C12.2833 12 12.5208 11.9042 12.7125 11.7125C12.9042 11.5208 13 11.2833 13 11V5C13 4.71667 12.9042 4.47917 12.7125 4.2875C12.5208 4.09583 12.2833 4 12 4C11.7167 4 11.4792 4.09583 11.2875 4.2875C11.0958 4.47917 11 4.71667 11 5V11C11 11.2833 11.0958 11.5208 11.2875 11.7125C11.4792 11.9042 11.7167 12 12 12Z" fill="#6B7280"/>
            </g>
          </svg>
        </button>
        <button class="icon-button send-button" id="chatbot-send" aria-label="Send message">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="16" viewBox="0 0 18 16" fill="none">
            <path d="M16.8 8.43205L1.4 14.9321C1.06667 15.0654 0.75 15.0362 0.45 14.8446C0.15 14.6529 0 14.3737 0 14.0071V1.00705C0 0.640385 0.15 0.361218 0.45 0.169551C0.75 -0.0221154 1.06667 -0.0512821 1.4 0.0820513L16.8 6.58205C17.2167 6.76538 17.425 7.07372 17.425 7.50705C17.425 7.94038 17.2167 8.24872 16.8 8.43205ZM2 12.5071L13.85 7.50705L2 2.50705V6.00705L8 7.50705L2 9.00705V12.5071Z" fill="#5386FA"/>
          </svg>
        </button>
      </div>
      <p class="privacy-text">Privacy and terms</p>
    </div>
  </div>
</div>

<style>
  .chatbot-container {
    position: fixed;
    bottom: 0.625rem;
    right: 2rem;
    z-index: 9999;
  }

  /* 遮罩层 */
  .chatbot-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--Grey-Gray-30, rgba(17, 24, 39, 0.40));
    backdrop-filter: blur(7.5px);
    z-index: 9998;
  }

  /* 悬浮按钮 */
  .chatbot-button {
    width: 3.125rem;
    height: 3.125rem;
    bottom: 6rem;
    position: relative;
    border-radius: 50%;
    border: 1px solid var(--AI-Gradient-Sky-Aurora-Medium, #FBE5CF);
    background: linear-gradient(322deg, rgba(251, 229, 207, 0.30) 14.44%, rgba(175, 201, 255, 0.30) 82.53%), #FFF;
    box-shadow: 0 0.75rem 2.5rem 0 rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(10px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.6s ease;
    padding: 0;
  }

  .chatbot-button.icon2 {
    border-radius: 50%;
    background: linear-gradient(142deg, rgba(251, 229, 207, 0.30) 13.69%, rgba(175, 201, 255, 0.30) 87.17%), #FFF;
  }

  .chatbot-button.hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.8);
  }

  .chatbot-button:hover:not(.hidden) {
    transform: scale(1.1);
    box-shadow: 0 0.75rem 2.5rem 0 rgba(0, 0, 0, 0.08);
  }

  .chatbot-icon {
    width: 1.875rem;
    height: 1.875rem;
    transition: opacity 0.3s ease;
  }

  /* Chatbot 弹窗 */
  .chatbot-popup {
    position: fixed;
    bottom: 0.625rem;
    right: 2rem;
    width: 100%;
    max-width: 25rem;
    height: auto;
    box-shadow: 0 5px 10px 0 rgba(0, 0, 0, 0.05), 0 15px 30px 0 rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(10px);
    max-height: calc(100vh - 5.375rem - 20px);
    border-radius: 1rem;
    display: none;
    flex-direction: column;
    overflow: hidden;
    animation: slideUp 0.3s ease;
    transition: all 0.3s ease;
    z-index: 10000;
  }

  .chatbot-popup.active {
    display: flex;
  }

  .chatbot-popup.fullscreen {
    top: 10px;
    bottom: 10px;
    right: 2rem;
    /* left: 2rem; */
    /* max-width: none; */
    max-height: none;
    height: auto;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Header */
  .chatbot-header {
    padding: 1rem;
    background: #FFF;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #E5E5E5;
  }

  .chatbot-header-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .chatbot-avatar {
    width: 1.875rem;
    height: 1.875rem;
    border-radius: 50%;
    object-fit: cover;
  }

  .chatbot-info h3 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    background: linear-gradient(90deg, #A855F7 0%, #6366F1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .chatbot-header-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .icon-button {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    transition: background 0.3s;
    width: 2rem;
    height: 2rem;
  }

  .icon-button:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .icon-button svg {
    color: #666;
  }

  /* Messages */
  .chatbot-messages {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    justify-content: end;
    gap: 1rem;
    min-height: 20rem;
  }

  :global(.message) {
    display: flex;
    gap: 0.5rem;
    animation: fadeIn 0.3s ease;
    align-items: flex-start;
  }

  .bot-message {
    justify-content: flex-start;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(.message-avatar) {
    width: 1.875rem;
    height: 1.875rem;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
  }

  :global(.message-content) {
    background: white;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    box-shadow: 0 0.125rem 0.5rem rgba(0, 0, 0, 0.05);
    max-width: 80%;
  }

  :global(.message-content p) {
    margin: 0;
    line-height: 1.6;
    color: #333;
    font-size: 0.95rem;
    width: fit-content;
    white-space: pre-wrap;
    word-break: break-word;
  }

  :global(.user-message) {
    flex-direction: row-reverse;
    justify-content: flex-start;
  }

  :global(.user-message .message-content) {
    color: var(--grey-gray-60-base, #111827);
    border-radius: 6px;
    background: var(--Azure-Azure-10, #E8F0FF);
  }

  /* Quick Actions */
  .quick-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    margin-left: 2.25rem;
    margin-right: 2.25rem;
    flex-wrap: wrap;
  }

  .quick-action-btn {
    padding: 0.75rem 0.5rem;
    border: 1px solid var(--Neutrals-White-00, #FFF);;
    background: var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
    border-radius: 0.5rem;
    cursor: pointer;
    font-size: 0.75rem;
    color: #333;
    transition: all 0.3s;
    white-space: nowrap;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1 0 0;
    align-self: stretch;
    text-align: center;
  }

  .quick-action-btn:hover {
    border-color: #A855F7;
    color: #A855F7;
    transform: translateY(-2px);
    box-shadow: 0 0.25rem 0.75rem rgba(168, 85, 247, 0.2);
  }

  /* Footer */
  .chatbot-footer {
    padding: 1rem 1.5rem;
    background: white;
    border-top: 1px solid #E5E5E5;
  }

  .chatbot-input-container {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    background: #F5F5F5;
    border-radius: 2rem;
    padding: 0.5rem 1rem;
  }

  .chatbot-input {
    flex: 1;
    padding: 0.5rem;
    border: none;
    background: transparent;
    font-size: 0.95rem;
    outline: none;
  }

  .chatbot-input::placeholder {
    color: #999;
  }

  .privacy-text {
    margin: 0.75rem 0 0 0;
    text-align: center;
    font-size: 0.8rem;
    color: #999;
  }

  @media (max-width: 768px) {
    .chatbot-container {
      bottom: 0.625rem;
      right: 1rem;
    }

    .chatbot-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--Grey-Gray-30, rgba(17, 24, 39, 0.40));
      backdrop-filter: blur(7.5px);
      z-index: 9998;
    }

    .chatbot-overlay.active {
      display: block;
    }

    .chatbot-popup {
      bottom: 0;
      right: 0;
      left: 0;
      max-width: none;
      width: 100%;
      height: auto;
      max-height: 70vh;
      border-radius: 1rem 1rem 0 0;
      border-radius: 12px;
      background: var(--Neutrals-White-10, rgba(255, 255, 255, 0.75));
      backdrop-filter: blur(20px);
    }

    .chatbot-popup.fullscreen {
      top: 0;
      right: 0;
      left: 0;
      max-height: 100vh;
      height: 100vh;
      border-radius: 0;
    }
  }
</style>

<script>
  // Chatbot 交互逻辑
  const toggleButton = document.getElementById('chatbot-toggle') as HTMLButtonElement;
  const closeButton = document.getElementById('chatbot-close');
  const fullscreenToggle = document.getElementById('fullscreen-toggle');
  const fullscreenIcon = document.getElementById('fullscreen-icon') as HTMLImageElement;
  const popup = document.getElementById('chatbot-popup');
  const overlay = document.getElementById('chatbot-overlay');
  const input = document.getElementById('chatbot-input') as HTMLInputElement;
  const sendButton = document.getElementById('chatbot-send');
  const messagesContainer = document.getElementById('chatbot-messages');
  const chatbotIcon = document.getElementById('chatbot-icon') as HTMLImageElement;

  // 图标循环切换
  let currentIcon = 1;
  const icon1Src = new URL('../assets/AIIcons.svg', import.meta.url).href;
  const icon2Src = new URL('../assets/AIIcons2.svg', import.meta.url).href;
  const fullScreenSrc = new URL('../assets/chatbot/fullScreen.svg', import.meta.url).href;
  const shrinkScreenSrc = new URL('../assets/chatbot/shirnkScreen.svg', import.meta.url).href;
  const userAvatarSrc = new URL('../assets/chatbot/UserAvatar.png', import.meta.url).href;
  const aiAvatarSrc = new URL('../assets/chatbot/AIAvatar.png', import.meta.url).href;

  let isFullscreen = false;

  const cycleIcon = () => {
    currentIcon = currentIcon === 1 ? 2 : 1;
    
    if (currentIcon === 1) {
      chatbotIcon.src = icon1Src;
      toggleButton?.classList.remove('icon2');
    } else {
      chatbotIcon.src = icon2Src;
      toggleButton?.classList.add('icon2');
    }
  };

  // 每1.5秒切换一次图标
  setInterval(cycleIcon, 1500);

  // 切换弹窗显示
  toggleButton?.addEventListener('click', () => {
    popup?.classList.add('active');
    overlay?.classList.add('active');
    toggleButton?.classList.add('hidden');
    input?.focus();
  });

  // 关闭弹窗
  const closePopup = () => {
    popup?.classList.remove('active');
    popup?.classList.remove('fullscreen');
    overlay?.classList.remove('active');
    toggleButton?.classList.remove('hidden');
    isFullscreen = false;
    if (fullscreenIcon) {
      fullscreenIcon.src = fullScreenSrc;
    }
  };

  closeButton?.addEventListener('click', closePopup);
  overlay?.addEventListener('click', closePopup);

  // 全屏切换
  fullscreenToggle?.addEventListener('click', () => {
    isFullscreen = !isFullscreen;
    if (isFullscreen) {
      popup?.classList.add('fullscreen');
      if (fullscreenIcon) {
        fullscreenIcon.src = shrinkScreenSrc;
      }
    } else {
      popup?.classList.remove('fullscreen');
      if (fullscreenIcon) {
        fullscreenIcon.src = fullScreenSrc;
      }
    }
  });

  // 加载 Leapin AI Agent SDK
  const loadLeapinSDK = () => {
    return new Promise<void>((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://cdn.leapin-ai.com/components/@kne-components/leapin-ai-agent-sdk/0.0.7/build/static/js/sdk-main.js';
      script.onload = () => resolve();
      script.onerror = () => reject(new Error('Failed to load Leapin SDK'));
      document.head.appendChild(script);
    });
  };

  // 初始化 SDK
  let sdkInstance: any = null;

  loadLeapinSDK().then(() => {
    if (typeof (window as any).leapinAiAgentSDK === 'function') {
      // SDK 已加载，但我们不使用它的UI，只使用API
      console.log('Leapin AI SDK loaded successfully');
    }
  }).catch(error => {
    console.error('Failed to load Leapin AI SDK:', error);
  });

  // 发送消息到 Leapin AI
  const sendToLeapinAI = async (message: string) => {
    try {
      const response = await fetch('https://app.leapin-ai.com/ai-agent', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer f0c31bf6-d230-4940-8327-1a55c5908d97`
        },
        body: JSON.stringify({
          message: message,
          secret: 'f0c31bf6-d230-4940-8327-1a55c5908d97'
        })
      });

      if (!response.ok) {
        throw new Error('Failed to send message');
      }

      const data = await response.json();
      return data.reply || data.message || 'Thank you for your question! Our team will get back to you soon.';
    } catch (error) {
      console.error('Error sending message to Leapin AI:', error);
      return 'Sorry, I encountered an error. Please try again later.';
    }
  };

  // 发送消息
  const sendMessage = async () => {
    const message = input?.value.trim();
    if (!message) return;

    // 添加用户消息
    const userMessage = document.createElement('div');
    userMessage.className = 'message user-message';
    userMessage.innerHTML = `
      <img class="message-avatar" src="${userAvatarSrc}" alt="User" />
      <div class="message-content">
        <p>${message}</p>
      </div>
    `;
    messagesContainer?.appendChild(userMessage);

    // 清空输入框
    if (input) input.value = '';

    // 滚动到底部
    messagesContainer?.scrollTo({
      top: messagesContainer.scrollHeight,
      behavior: 'smooth'
    });

    // 显示加载状态
    const loadingMessage = document.createElement('div');
    loadingMessage.className = 'message bot-message';
    loadingMessage.id = 'loading-message';
    loadingMessage.innerHTML = `
      <img class="message-avatar" src="${aiAvatarSrc}" alt="AI" />
      <div class="message-content">
        <p>Thinking...</p>
      </div>
    `;
    messagesContainer?.appendChild(loadingMessage);

    messagesContainer?.scrollTo({
      top: messagesContainer.scrollHeight,
      behavior: 'smooth'
    });

    // 调用 Leapin AI API
    const reply = await sendToLeapinAI(message);

    // 移除加载消息
    loadingMessage.remove();

    // 添加 AI 回复
    const botMessage = document.createElement('div');
    botMessage.className = 'message bot-message';
    botMessage.innerHTML = `
      <img class="message-avatar" src="${aiAvatarSrc}" alt="AI" />
      <div class="message-content">
        <p>${reply}</p>
      </div>
    `;
    messagesContainer?.appendChild(botMessage);
    
    messagesContainer?.scrollTo({
      top: messagesContainer.scrollHeight,
      behavior: 'smooth'
    });
  };

  sendButton?.addEventListener('click', sendMessage);

  input?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      sendMessage();
    }
  });

  // 快捷操作按钮
  const quickActionButtons = document.querySelectorAll('.quick-action-btn');
  quickActionButtons.forEach(button => {
    button.addEventListener('click', () => {
      const text = button.textContent?.trim();
      if (text && input) {
        input.value = text;
        sendMessage();
      }
    });
  });
</script>
