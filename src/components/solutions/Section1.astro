---
import Card from './Card.astro';
import Avatar from '../../assets/solutions/section/section1-avatar.png';
import Score from '../../assets/solutions/section/section1-score.png';
import cnAvatar from '../../assets/solutions/section/cn/section1-avatar.png';
import cnScore from '../../assets/solutions/section/cn/section1-score.png';
---

<section class="section-container" id="solutions-section-1">
    <div class="container">
        <div class="section-avatar">
            <picture>
                <img src={Avatar.src} alt="" data-en-src={Avatar.src} data-cn-src={cnAvatar.src} class="lang-image">
            </picture>
        </div>
        <div class="section-score">
            <picture>
                <img src={Score.src} alt="" data-en-src={Score.src} data-cn-src={cnScore.src} class="lang-image">
            </picture>
        </div>
        <Card index={1} itemLength={5} className="card-section1"></Card>
    </div>
</section>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  import { inView } from '../../utils/inView';
  loadTranslations();
    // 根据语言切换图片
    const updateImages = () => {
        const currentLang = localStorage.getItem('language') || 'en';
        const images = document.querySelectorAll('.lang-image');
        
        images.forEach((img) => {
            const enSrc = img.getAttribute('data-en-src');
            const cnSrc = img.getAttribute('data-cn-src');
            
            if (currentLang === 'zh' && cnSrc) {
                img.setAttribute('src', cnSrc);
            } else if (enSrc) {
                img.setAttribute('src', enSrc);
            }
        });
    };

    // 页面加载时更新
    updateImages();

    // 监听语言切换事件
    window.addEventListener('languageChanged', updateImages);
  const isMobile = window.matchMedia('(max-width: 768px)').matches;
  // Intersection Observer 监听 features 是否在可视区域内
  if (isMobile && typeof window !== 'undefined') {
    inView({id: "solutions-section-1", threshold: 0.2});
  }
</script>

<style>
    .section-container {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .container {
        display: flex;
        justify-content: space-between;
        position: relative;
    }

    .section-avatar {
        position: absolute;
        padding: 1rem;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
        max-width: 25.875rem;
        transition: all 0.6s ease;
    }

    .section-score {
        position: absolute;
        width: 36.5rem;
        height: fit-content;
        padding: 1rem;
        /* flex-direction: column; */
        /* justify-content: center; */
        align-items: center;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
        position: relative;
        transform: translateX(14rem) translateY(12rem);
        z-index: 1;
        transition: all 0.6s ease;
    }

	@media (max-width: 768px) {
        .container {
            flex-direction: column;
            margin: 0;
            padding: 0 1rem 7.5rem 1rem;
            flex-direction: column-reverse;
        }
        .section-avatar,
        .section-score {
            padding: 0.375rem;
        }
		.section-avatar {
            width: calc(100% - 2rem);
			position: relative;
		}
        .section-score {
            position: absolute;
            width: calc(100% - 3.75rem);
        }
        .in-view .section-avatar {
            transform: translateX(0) translateY(0) rotate(0);
		}

        .in-view .section-score {
            transform: translateX(1.875rem) translateY(7.5rem);
        }

        :global(.card-section1) {
            transform: translateX(1.875rem) translateY(100%) rotate(45deg);
        }
        .in-view :global(.card-section1) {
            transform: translateX(0) translateY(0);
        }
        .section-score {
            transform: translateX(0) translateY(0);
        }
        .section-avatar {
            transform: translateX(0) translateY(0) rotate(-45deg);
		}
	}
</style>