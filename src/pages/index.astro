---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Partners from '../components/Partners.astro';
import Features from '../components/Features.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import Stats from '../components/Stats.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<Header />
	<main class="scroll-container">
		<section class="scroll-section" data-section="hero">
			<Hero />
		</section>
		<section class="scroll-section partners-section" data-section="partners">
			<Partners />
		</section>
		<section class="scroll-section" data-section="features">
			<Features />
		</section>
		<section class="scroll-section" data-section="showcase">
			<ProductShowcase />
		</section>
		<section class="scroll-section" data-section="stats">
			<Stats />
		</section>
		<section class="scroll-section" data-section="cta">
			<CTA />
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.partners-section {
		min-height: auto;
	}

	/* PC 端启用滚动捕捉 */
	@media (min-width: 769px) {

		/* 除了 hero 外，其他区域需要留出 header 高度 */
		.scroll-section:not([data-section="hero"]) {
			scroll-margin-top: 4.75rem;
		}
	}
</style>
